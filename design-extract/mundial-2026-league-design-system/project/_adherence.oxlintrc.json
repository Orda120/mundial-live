{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/league-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|mono|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, mono, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|sky|emerald|amber|rose)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'sky' | 'emerald' | 'amber' | 'rose'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tone|size|block|disabled|icon|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, tone, size, block, disabled, icon, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sky|emerald|amber|rose)$/]",
        "message": "<Button> tone must be one of 'sky' | 'emerald' | 'amber' | 'rose'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|leader|padded|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, leader, padded, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConnectionDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:connected|size|pulse|style|key|ref|className|style|children)$/]",
        "message": "<ConnectionDot> doesn't accept that prop. Declared props: connected, size, pulse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Flag'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|lg|withName|style|key|ref|className|style|children)$/]",
        "message": "<Flag> doesn't accept that prop. Declared props: code, lg, withName, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|tone|disabled|block|mark|icon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: children, selected, tone, disabled, block, mark, icon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sky|emerald|amber)$/]",
        "message": "<Pill> tone must be one of 'sky' | 'emerald' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='mark'] > Literal[value!=/^(?:hit|miss)$/]",
        "message": "<Pill> mark must be one of 'hit' | 'miss'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayerDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|idx|size|style|key|ref|className|style|children)$/]",
        "message": "<PlayerDot> doesn't accept that prop. Declared props: name, idx, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:a|b|onChange|locked|style|key|ref|className|style|children)$/]",
        "message": "<ScoreInput> doesn't accept that prop. Declared props: a, b, onChange, locked, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Section'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|badge|sub|defaultOpen|children|style|key|ref|className|style|children)$/]",
        "message": "<Section> doesn't accept that prop. Declared props: title, badge, sub, defaultOpen, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: key, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|disabled|type|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, value, onChange, placeholder, disabled, type, style, inputStyle."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
