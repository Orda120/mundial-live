{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mundial-live-scores",
  "main": "src/index.js",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "triggers": {
    "crons": ["* * * * *"]
  },
  "vars": {
    "FIREBASE_DATABASE_URL": "https://mundial-live-orda120-default-rtdb.europe-west1.firebasedatabase.app"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
